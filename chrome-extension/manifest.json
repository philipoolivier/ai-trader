{
  "manifest_version": 3,
  "name": "AI Trader - Chart Capture",
  "version": "1.0.0",
  "description": "Auto-capture TradingView charts across multiple timeframes for AI analysis",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.tradingview.com/*",
    "*://ai-trader-mocha.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://ai-trader-mocha.vercel.app/*",
        "http://localhost:3000/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icons/icon-128.png"
  }
}
